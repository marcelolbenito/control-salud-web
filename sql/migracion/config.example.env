# Copiar a config.env y ajustar (no subir config.env con contraseñas reales)
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3307
MYSQL_DATABASE=control_salud
MYSQL_USER=root
MYSQL_PASSWORD=salud_root_dev

MDB_PATH=C:\Control Salud\Datos.mdb
MDB_PASSWORD=control333

# SQL Server restaurado desde Datos.bak
SQLSERVER_HOST=.\SQLEXPRESS
SQLSERVER_DATABASE=Datos
SQLSERVER_SCHEMA=dbo
SQLSERVER_TRUSTED=1
SQLSERVER_TRUST_CERT=1
# Si SQLSERVER_TRUSTED=0, usar SQLSERVER_USER/SQLSERVER_PASSWORD
SQLSERVER_USER=sa
SQLSERVER_PASSWORD=

# Salida del generador SQL Server -> MySQL (todas las tablas)
SQLSERVER_TO_MYSQL_OUT=C:\Control Salud\sql\migracion\migration_from_sqlserver_full.sql
SQLSERVER_INSERT_BATCH_SIZE=200
# Opcional para pruebas: regex de tablas a exportar (vacío = todas)
SQLSERVER_ONLY_TABLE_REGEX=
